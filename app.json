{
  "expo": {
    "name": "expo-sink",
    "slug": "expo-sink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "exposink",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.tekibo.exposink",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSCameraUsageDescription": "Testing camera",
        "NSMicrophoneUsageDescription": "Testing microphone",
        "NSPhotoLibraryUsageDescription": "Testing photo library",
        "NSPhotoLibraryAddUsageDescription": "Saving media",
        "NSLocationWhenInUseUsageDescription": "Testing location",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Testing background location",
        "NSLocationAlwaysUsageDescription": "Testing always-on location",
        "NSBluetoothAlwaysUsageDescription": "Testing bluetooth",
        "NSBluetoothPeripheralUsageDescription": "Testing bluetooth",
        "NSContactsUsageDescription": "Testing contacts",
        "NSCalendarsUsageDescription": "Testing calendar",
        "NSRemindersUsageDescription": "Testing reminders",
        "NSFaceIDUsageDescription": "Testing FaceID",
        "NSMotionUsageDescription": "Testing motion sensors",
        "NSHealthShareUsageDescription": "Testing health read",
        "NSHealthUpdateUsageDescription": "Testing health write",
        "NSHomeKitUsageDescription": "Testing HomeKit",
        "NFCReaderUsageDescription": "Testing NFC",
        "NSLocalNetworkUsageDescription": "Testing local network",
        "NSNearbyInteractionUsageDescription": "Testing nearby interaction",
        "NSAppleMusicUsageDescription": "Testing media library",
        "NSUserTrackingUsageDescription": "Testing tracking",
        "NSSpeechRecognitionUsageDescription": "Testing speech recognition",
        "NSSiriUsageDescription": "Testing Siri",
        "NSVideoSubscriberAccountUsageDescription": "Testing TV provider",
        "NSSystemAdministrationUsageDescription": "Testing system control"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tekibo.exposink",
      "permissions": [
        "ACCEPT_HANDOVER",
        "ACCESS_BACKGROUND_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_MEDIA_LOCATION",
        "ACCESS_NETWORK_STATE",
        "ACCESS_NOTIFICATION_POLICY",
        "ACCESS_WIFI_STATE",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "BODY_SENSORS",
        "BODY_SENSORS_BACKGROUND",
        "CALL_PHONE",
        "CAMERA",
        "CHANGE_NETWORK_STATE",
        "CHANGE_WIFI_STATE",
        "FOREGROUND_SERVICE",
        "GET_ACCOUNTS",
        "INTERNET",
        "MANAGE_EXTERNAL_STORAGE",
        "MODIFY_AUDIO_SETTINGS",
        "NEARBY_WIFI_DEVICES",
        "NFC",
        "POST_NOTIFICATIONS",
        "PROCESS_OUTGOING_CALLS",
        "READ_CALENDAR",
        "READ_CALL_LOG",
        "READ_CONTACTS",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_PHONE_NUMBERS",
        "READ_PHONE_STATE",
        "READ_SMS",
        "RECEIVE_BOOT_COMPLETED",
        "RECEIVE_MMS",
        "RECEIVE_SMS",
        "RECORD_AUDIO",
        "SCHEDULE_EXACT_ALARM",
        "SEND_SMS",
        "SYSTEM_ALERT_WINDOW",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "WAKE_LOCK",
        "WRITE_CALENDAR",
        "WRITE_CALL_LOG",
        "WRITE_CONTACTS",
        "WRITE_EXTERNAL_STORAGE",
        "WRITE_SETTINGS",
        "WRITE_SMS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "launcher"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ExpoSink needs camera access for testing apps.",
          "microphonePermission": "ExpoSink needs microphone access for testing apps."
        }
      ],
      "expo-maps",
      "expo-audio",
      "expo-background-task",
      "expo-font",
      "expo-image",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ExpoSink needs location access for testing apps."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "ExpoSink needs contacts access for testing apps."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "ExpoSink needs calendar access for testing apps."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ExpoSink needs photo library access for testing apps.",
          "cameraPermission": "ExpoSink needs camera access for testing apps.",
          "microphonePermission": "ExpoSink needs microphone access for testing apps."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ExpoSink needs photo library access for testing apps.",
          "savePhotosPermission": "ExpoSink needs permission to save photos for testing apps."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ExpoSink needs FaceID access for testing auth flows."
        }
      ],
      "expo-mail-composer",
      "expo-secure-store",
      "expo-sharing",
      "expo-sqlite",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "ExpoSink needs tracking permission for testing analytics."
        }
      ],
      "expo-video",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}